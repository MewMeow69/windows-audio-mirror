<Window x:Class="WindowsAudioMirror.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Windows Audio Mirror" Height="532" Width="560"
        MinWidth="480" MinHeight="340"
        Background="#1A1A1A"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <DataTemplate x:Key="DeviceItemTemplate">
            <TextBlock Text="{Binding Name}" ToolTip="{Binding DeviceHint}" />
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Windows Audio Mirror" FontSize="22" FontWeight="SemiBold"
                   Foreground="#ECECEC" Margin="0,0,0,12" />

        <Border Grid.Row="1" Background="#242424" BorderBrush="#3A3A3A" BorderThickness="1"
                CornerRadius="4" Padding="20">
            <StackPanel>
                <TextBlock Text="Duplicate your default playback audio to a second output device."
                           Foreground="#A0A0A0" TextWrapping="Wrap" Margin="0,0,0,18" />

                <TextBlock Text="SOURCE" FontSize="11" FontWeight="SemiBold"
                           Foreground="#707070" Margin="0,0,0,4" />
                <ComboBox x:Name="cboSource"
                          ItemTemplate="{StaticResource DeviceItemTemplate}"
                          Margin="0,0,0,14" />

                <TextBlock Text="TARGET" FontSize="11" FontWeight="SemiBold"
                           Foreground="#707070" Margin="0,0,0,4" />
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="cboTarget"
                              ItemTemplate="{StaticResource DeviceItemTemplate}"
                              Margin="0,0,8,0" />
                    <Button x:Name="btnRefresh" Grid.Column="1"
                            Content="&#x21BB;" Width="38" FontSize="16"
                            Background="#333333" ToolTip="Refresh device list" />
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="btnStartMirror" Content="Start Mirror" IsEnabled="False" />
                    <Button x:Name="btnStopMirror" Grid.Column="2" Content="Stop"
                            IsEnabled="False" Background="#E53935" />
                </Grid>

                <Border Margin="0,18,0,0" Background="#2E2E2E"
                        CornerRadius="4" Padding="12,10" MinHeight="40">
                    <TextBlock x:Name="lblMirrorStatus" Text="Stopped"
                               Foreground="#A0A0A0" VerticalAlignment="Center" />
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Margin="0,12,0,0" Background="#242424"
                CornerRadius="4" Padding="12,7">
            <TextBlock x:Name="lblStatusBar" Text="Ready" FontSize="12" Foreground="#A0A0A0" />
        </Border>
    </Grid>
</Window>
